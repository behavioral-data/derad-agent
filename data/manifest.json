{
  "schema_version": 1,
  "project": "derad-agent",
  "policy": {
    "track_in_git": [
      "data/samples/*.tsv",
      "data/manifest.json",
      "data/checksums.sha256"
    ],
    "do_not_track_in_git": [
      "data/notes-*.tsv",
      "indexes/**",
      "results/**"
    ]
  },
  "external_data": {
    "env_var": "DERAD_AGENT_NOTES_TSV_ROOT",
    "description": "Path to local/raw Community Notes TSV files (outside git)."
  },
  "files": [
    {
      "path": "data/samples/notes-mini.tsv",
      "required": true,
      "description": "Small fixture for local sanity checks and docs examples.",
      "sha256": "007ebc8457f77e3172f13e50ee24d349ff19ee67bcb721d7c02c735296cd2d24"
    }
  ]
}
